<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="52dp"
        android:paddingBottom="40dp">

        <!-- ── Header ─────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ESSENTIAL KEY"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.12"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BUTTON REMAPPER FOR NOTHING PHONE"
            android:textColor="#444444"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.18"
            android:layout_marginTop="4dp" />

        <!-- ── Status row ─────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="28dp">

            <View
                android:id="@+id/viewStatusDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="#FF3533" />

            <TextView
                android:id="@+id/tvStatusText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="NEEDS SETUP"
                android:textColor="#888888"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.2"
                android:layout_marginStart="10dp" />
        </LinearLayout>

        <!-- ── Divider ────────────────────────────────────────────────── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1A1A1A"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp" />

        <!-- ── Enable Remap ───────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="REMAP BUTTON"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Intercept and replace the Essential Key"
                    android:textColor="#555555"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchEnable"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:thumbTint="#FFFFFF"
                app:trackTint="#333333"
                app:trackTintMode="src_in" />
        </LinearLayout>

        <!-- ── Divider ────────────────────────────────────────────────── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1A1A1A"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp" />

        <!-- ── Mode ───────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MODE"
            android:textColor="#666666"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.25"
            android:layout_marginBottom="12dp" />

        <RadioGroup
            android:id="@+id/rgMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/rbSingle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="SINGLE ACTION"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.08"
                android:buttonTint="#FFFFFF"
                android:paddingStart="12dp" />

            <RadioButton
                android:id="@+id/rbPanel"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="QUICK PANEL"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.08"
                android:buttonTint="#FFFFFF"
                android:paddingStart="12dp"
                android:layout_marginTop="4dp" />
        </RadioGroup>

        <!-- ── Single Action Config ───────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/layoutSingleAction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:background="#0D0D0D"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTION"
                android:textColor="#666666"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.25"
                android:layout_marginBottom="10dp" />

            <Spinner
                android:id="@+id/spinnerAction"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#1A1A1A"
                android:popupBackground="#0D0D0D" />
        </LinearLayout>

        <!-- ── Quick Panel Config ─────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/layoutPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:background="#0D0D0D"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PANEL ACTIONS"
                android:textColor="#666666"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.25"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/layoutQuickActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

        <!-- ── Divider ────────────────────────────────────────────────── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1A1A1A"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="20dp" />

        <!-- ── Button Detection ───────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BUTTON DETECTION"
            android:textColor="#666666"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.25"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap DETECT then press your Essential Key to auto-identify its keycode."
            android:textColor="#555555"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvDetectStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NOT DETECTED – USING AUTO"
            android:textColor="#888888"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnDetect"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="DETECT"
                android:textColor="#000000"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:backgroundTint="#FFFFFF"
                android:letterSpacing="0.12"
                style="@style/Widget.MaterialComponents.Button" />

            <Button
                android:id="@+id/btnClearDetect"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="CLEAR"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:backgroundTint="#1A1A1A"
                android:letterSpacing="0.12"
                android:visibility="gone"
                style="@style/Widget.MaterialComponents.Button" />
        </LinearLayout>

        <!-- ── Divider ────────────────────────────────────────────────── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1A1A1A"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="20dp" />

        <!-- ── Setup / Permissions ────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SETUP"
            android:textColor="#666666"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.25"
            android:layout_marginBottom="14dp" />

        <!-- Accessibility -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <View
                android:id="@+id/viewDotAccessibility"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="#FF3533"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACCESSIBILITY SERVICE"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tvAccessibilityState"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="REQUIRED"
                    android:textColor="#FF3533"
                    android:textSize="10sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <Button
                android:id="@+id/btnAccessibility"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="OPEN"
                android:textColor="#000000"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:backgroundTint="#FFFFFF"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                style="@style/Widget.MaterialComponents.Button" />
        </LinearLayout>

        <!-- Overlay -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <View
                android:id="@+id/viewDotOverlay"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="#FF3533"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OVERLAY PERMISSION"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tvOverlayState"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="REQUIRED"
                    android:textColor="#FF3533"
                    android:textSize="10sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <Button
                android:id="@+id/btnOverlay"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="OPEN"
                android:textColor="#000000"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:backgroundTint="#FFFFFF"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                style="@style/Widget.MaterialComponents.Button" />
        </LinearLayout>

        <!-- DND -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:id="@+id/viewDotDnd"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="#FF3533"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DO NOT DISTURB ACCESS"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tvDndState"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="REQUIRED"
                    android:textColor="#FF3533"
                    android:textSize="10sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <Button
                android:id="@+id/btnDnd"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="OPEN"
                android:textColor="#000000"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:backgroundTint="#FFFFFF"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                style="@style/Widget.MaterialComponents.Button" />
        </LinearLayout>

        <!-- ── Footer ─────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="nothing. phone (3a) · essential key remapper"
            android:textColor="#2A2A2A"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:layout_marginTop="36dp" />

    </LinearLayout>
</ScrollView>
