<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.EssentialRemap" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/nothing_white</item>
        <item name="colorPrimaryVariant">@color/nothing_surface</item>
        <item name="colorOnPrimary">@color/nothing_black</item>
        <item name="colorSecondary">@color/nothing_red</item>
        <item name="colorOnSecondary">@color/nothing_white</item>
        <item name="colorSurface">@color/nothing_surface</item>
        <item name="colorOnSurface">@color/nothing_white</item>
        <item name="android:colorBackground">@color/nothing_black</item>
        <item name="android:textColorPrimary">@color/nothing_white</item>
        <item name="android:textColorSecondary">@color/nothing_text_secondary</item>
        <item name="android:windowBackground">@color/nothing_black</item>
        <item name="android:statusBarColor">@color/nothing_black</item>
        <item name="android:navigationBarColor">@color/nothing_black</item>
        <item name="android:fontFamily">monospace</item>

        <!-- Spinner dropdown -->
        <item name="spinnerDropDownItemStyle">@style/NothingSpinnerDropDown</item>

        <!-- Switch -->
        <item name="switchStyle">@style/NothingSwitch</item>
    </style>

    <style name="NothingSpinnerDropDown" parent="Widget.AppCompat.TextView.SpinnerItem">
        <item name="android:textColor">@color/nothing_white</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:background">@color/nothing_surface</item>
    </style>

    <style name="NothingSwitch" parent="Widget.MaterialComponents.CompoundButton.Switch">
        <item name="thumbTint">@color/nothing_white</item>
        <item name="trackTint">@color/nothing_border</item>
    </style>

    <style name="NothingDialog" parent="Theme.MaterialComponents.Dialog.Alert">
        <item name="android:background">@color/nothing_surface</item>
        <item name="android:textColorPrimary">@color/nothing_white</item>
        <item name="android:textColor">@color/nothing_white</item>
        <item name="android:fontFamily">monospace</item>
        <item name="colorPrimary">@color/nothing_white</item>
        <item name="buttonBarPositiveButtonStyle">@style/NothingDialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/NothingDialogButtonOutline</item>
    </style>

    <style name="NothingDialogButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/nothing_black</item>
        <item name="backgroundTint">@color/nothing_white</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

    <style name="NothingDialogButtonOutline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/nothing_white</item>
        <item name="strokeColor">@color/nothing_border</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

</resources>
